<view class="msg-page">
  <view class="msg-header">
    <view class="msg-title">消息中心</view>
    <view class="msg-subtitle">按类型查看并处理未读消息</view>
  </view>

  <van-notice-bar left-icon="volume-o" text="当前有 2 条未读消息，建议优先处理审批消息。" />

  <view class="msg-section">
    <van-tabs active="{{activeTab}}" color="#1f6b57" line-width="24" bind:change="handleTabChange">
      <van-tab name="0" title="全部" />
      <van-tab name="1" title="审批" />
      <van-tab name="2" title="系统" />
    </van-tabs>

    <van-cell-group wx:if="{{visibleNotices.length}}" inset="{{false}}" border="{{false}}" class="msg-list-group">
      <van-cell
        wx:for="{{visibleNotices}}"
        wx:key="id"
        is-link
        data-id="{{item.id}}"
        bindtap="handleOpen"
        title="{{item.title}}"
        label="{{item.summary}}"
        value="{{item.time}}"
      >
        <van-tag wx:if="{{item.unread}}" slot="right-icon" type="danger" plain>未读</van-tag>
      </van-cell>
    </van-cell-group>

    <view wx:else class="msg-empty">
      <view class="msg-empty-title">暂无消息</view>
      <view class="msg-empty-copy">当前筛选条件下没有待处理消息</view>
    </view>
  </view>
</view>