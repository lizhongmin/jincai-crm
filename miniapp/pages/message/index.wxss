.msg-page {
  min-height: 100vh;
  padding: 20rpx 24rpx 36rpx;
  background: #f5f7f9;
}

.msg-header {
  padding: 6rpx 2rpx 14rpx;
}

.msg-title {
  font-size: 42rpx;
  line-height: 1.2;
  color: #16362f;
  font-weight: 700;
}

.msg-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6f837c;
}

.msg-section {
  margin-top: 14rpx;
  border-radius: 14rpx;
  border: 1rpx solid #e5ece8;
  background: #ffffff;
  overflow: hidden;
}

.msg-empty {
  padding: 56rpx 24rpx;
  text-align: center;
}

.msg-empty-title {
  font-size: 30rpx;
  color: #16362f;
  font-weight: 700;
}

.msg-empty-copy {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6f837c;
}
