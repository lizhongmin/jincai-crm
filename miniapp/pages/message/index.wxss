.msg-page {
  min-height: 100vh;
  padding: 20rpx 24rpx 36rpx;
  background: #f5f7f9;
}

.msg-header {
  padding: 8rpx 4rpx 14rpx;
}

.msg-title {
  font-size: 42rpx;
  line-height: 1.2;
  color: #16362f;
  font-weight: 700;
}

.msg-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6f837c;
}

.msg-filter {
  margin-top: 14rpx;
  display: flex;
  gap: 12rpx;
}

.msg-filter-item {
  min-width: 116rpx;
  height: 56rpx;
  padding: 0 18rpx;
  border-radius: 28rpx;
  border: 1rpx solid #dce6e1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #60756e;
  background: #f8fbf9;
}

.msg-filter-item.active {
  background: #e8f3ee;
  border-color: #95bcaf;
  color: #1f6b57;
  font-weight: 700;
}

.msg-list {
  margin-top: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.msg-item {
  padding: 18rpx;
  border-radius: 14rpx;
  border: 1rpx solid #e5ece8;
  background: #fff;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.msg-main {
  flex: 1;
  min-width: 0;
}

.msg-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.msg-item-title {
  font-size: 28rpx;
  color: #16362f;
  font-weight: 700;
  line-height: 1.35;
}

.msg-item-summary {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #60756e;
}

.msg-side {
  font-size: 22rpx;
  color: #8a9c95;
  white-space: nowrap;
  margin-top: 2rpx;
}

.msg-empty {
  margin-top: 18rpx;
  padding: 60rpx 24rpx;
  border: 1rpx solid #e5ece8;
  border-radius: 14rpx;
  background: #fff;
  text-align: center;
}

.msg-empty-title {
  font-size: 30rpx;
  color: #16362f;
  font-weight: 700;
}

.msg-empty-copy {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6f837c;
}