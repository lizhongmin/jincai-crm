<view class="cl-page">
  <view class="cl-header">
    <view class="cl-title">客户</view>
    <view class="cl-subtitle">列表、筛选与快速新增</view>
  </view>

  <view class="cl-toolbar">
    <van-search
      value="{{keyword}}"
      placeholder="搜索客户姓名或手机号"
      shape="round"
      bind:change="handleKeywordInput"
      bind:search="handleSearch"
    />

    <van-tabs active="{{activeTab}}" color="#1f6b57" line-width="24" bind:change="handleTabChange">
      <van-tab name="0" title="全部({{stats.all}})" />
      <van-tab name="1" title="高意向({{stats.high}})" />
      <van-tab name="2" title="最近更新({{stats.recent}})" />
    </van-tabs>
  </view>

  <van-cell-group wx:if="{{visibleCustomers.length}}" inset="{{false}}" border="{{false}}" class="cl-list-group">
    <van-cell
      wx:for="{{visibleCustomers}}"
      wx:key="id"
      is-link
      data-id="{{item.id}}"
      bindtap="handleOpenDetail"
      title="{{item.name}}"
      value="详情"
      label="{{item.phone}} · {{item.sourceLabel}} · {{item.intentionLevelLabel}}"
    />
  </van-cell-group>

  <van-empty wx:else class="cl-empty" image="search" description="暂无客户数据" />

  <view class="cl-bottom-bar">
    <van-button type="primary" block custom-class="cl-create-btn" bindtap="handleCreate">新增客户</van-button>
  </view>
</view>