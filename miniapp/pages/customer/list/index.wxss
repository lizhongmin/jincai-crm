.cl-page {
  min-height: 100vh;
  padding: 20rpx 24rpx 140rpx;
  background: #f5f7f9;
}

.cl-header {
  padding: 6rpx 2rpx 14rpx;
}

.cl-title {
  font-size: 42rpx;
  line-height: 1.2;
  color: #16362f;
  font-weight: 700;
}

.cl-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6f837c;
}

.cl-toolbar {
  border-radius: 14rpx;
  border: 1rpx solid #e5ece8;
  background: #ffffff;
  padding: 14rpx;
}

.cl-list-group {
  margin-top: 14rpx;
  border-radius: 14rpx;
  border: 1rpx solid #e5ece8;
  background: #ffffff;
  overflow: hidden;
}

.cl-empty {
  margin-top: 16rpx;
  border-radius: 14rpx;
  border: 1rpx solid #e5ece8;
  background: #ffffff;
}

.cl-bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 14rpx 20rpx calc(env(safe-area-inset-bottom) + 14rpx);
  background: #ffffff;
  border-top: 1rpx solid #e5ece8;
}