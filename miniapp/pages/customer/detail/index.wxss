.inline-tag {
  padding: 0 6rpx;
}

.muted-tag {
  color: var(--text-2) !important;
  border-color: rgba(139, 157, 150, 0.4) !important;
  background: rgba(238, 244, 241, 0.9) !important;
}

.detail-remark {
  padding: 24rpx;
  border-radius: 24rpx;
  background: var(--surface-soft);
  color: var(--text-2);
  font-size: 25rpx;
  line-height: 1.8;
}

.secondary-product-button,
.product-button {
  flex: 1;
}
