<view class="pf-page">
  <view class="pf-user-card">
    <view class="pf-avatar">{{profile && profile.fullName ? profile.fullName.slice(0, 1) : '袋'}}</view>
    <view class="pf-user-main">
      <view class="pf-name">{{profile && (profile.fullName || profile.username) || '袋鼠旅客通用户'}}</view>
      <view class="pf-meta">{{profile && profile.username ? profile.username : '已绑定微信登录'}}</view>
    </view>
    <van-tag type="primary" plain>已绑定</van-tag>
  </view>

  <view class="pf-section">
    <view class="pf-section-title">快捷入口</view>
    <van-grid column-num="4" gutter="10" border="{{false}}">
      <van-grid-item
        wx:for="{{quickEntries}}"
        wx:key="id"
        text="{{item.title}}"
        data-url="{{item.url}}"
        data-tab="{{item.tab}}"
        bindtap="handleOpen"
      />
    </van-grid>
  </view>

  <view class="pf-section">
    <view class="pf-section-title">账户设置</view>
    <van-cell-group inset="{{false}}" border="{{false}}">
      <van-cell
        wx:for="{{entries}}"
        wx:key="id"
        title="{{item.title}}"
        label="{{item.desc}}"
        is-link
        data-url="{{item.url}}"
        bindtap="handleOpen"
      />
    </van-cell-group>
  </view>

  <view class="pf-section">
    <van-button type="default" block custom-class="pf-logout-btn" bindtap="handleLogout">
      退出登录
    </van-button>
  </view>
</view>