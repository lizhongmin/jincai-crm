.pf-page {
  min-height: 100vh;
  padding: 20rpx 24rpx 36rpx;
  background: #f5f7f9;
}

.pf-card {
  padding: 24rpx;
  border-radius: 16rpx;
  border: 1rpx solid #e5ece8;
  background: #ffffff;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.pf-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #1f6b57;
  color: #fff;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
}

.pf-info {
  flex: 1;
  min-width: 0;
}

.pf-name {
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #16362f;
}

.pf-meta {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #6f837c;
}

.pf-section {
  margin-top: 14rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  border: 1rpx solid #e5ece8;
  background: #ffffff;
}

.pf-section-title {
  font-size: 28rpx;
  color: #16362f;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.pf-logout-btn {
  color: #435852;
}