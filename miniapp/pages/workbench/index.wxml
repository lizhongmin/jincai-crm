<view class="wb-page">
  <view class="wb-header">
    <view class="wb-title">工作台</view>
    <view class="wb-subtitle">今天优先处理高意向客户与审批任务</view>
  </view>

  <van-notice-bar left-icon="volume-o" text="当前有 3 项待办，请优先处理高优先任务。" />

  <view class="wb-section">
    <view class="wb-section-title">关键指标</view>
    <view class="wb-metrics">
      <view wx:for="{{metrics}}" wx:key="id" class="wb-metric-item">
        <view class="wb-metric-value">{{item.value}}</view>
        <view class="wb-metric-label">{{item.label}}</view>
      </view>
    </view>
  </view>

  <view class="wb-section">
    <view class="wb-section-title">快捷操作</view>
    <van-grid column-num="4" gutter="10" border="{{false}}">
      <van-grid-item
        wx:for="{{quickActions}}"
        wx:key="id"
        text="{{item.title}}"
        data-url="{{item.url}}"
        data-tab="{{item.tab}}"
        bindtap="handleOpen"
      />
    </van-grid>
  </view>

  <view class="wb-section">
    <view class="wb-section-head">
      <view class="wb-section-title">待办清单</view>
      <van-tag type="primary" plain>今日</van-tag>
    </view>
    <van-cell-group inset="{{false}}" border="{{false}}">
      <van-cell
        wx:for="{{todos}}"
        wx:key="id"
        title="{{item.title}}"
        label="{{item.meta}}"
        value="{{item.level}}"
        is-link
        data-url="{{item.url}}"
        data-tab="{{item.tab}}"
        bindtap="handleOpen"
      />
    </van-cell-group>
  </view>
</view>