.wb-page {
  min-height: 100vh;
  padding: 20rpx 24rpx 36rpx;
  background: #f5f7f9;
}

.wb-header {
  padding: 6rpx 2rpx 14rpx;
}

.wb-title {
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #16362f;
}

.wb-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6f837c;
}

.wb-section {
  margin-top: 14rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  border: 1rpx solid #e5ece8;
  background: #ffffff;
}

.wb-section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.wb-section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #16362f;
  margin-bottom: 12rpx;
}

.wb-metrics {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
}

.wb-metric-item {
  padding: 16rpx 10rpx;
  border-radius: 12rpx;
  border: 1rpx solid #e8efeb;
  background: #f9fbfa;
  text-align: center;
}

.wb-metric-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #16362f;
}

.wb-metric-label {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #6f837c;
}
