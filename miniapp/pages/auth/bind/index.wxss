.bind-page {
  min-height: 100vh;
  padding: 20rpx 24rpx 36rpx;
  background: #f5f7f9;
}

.bind-header {
  padding: 8rpx 2rpx 14rpx;
}

.bind-title {
  font-size: 42rpx;
  line-height: 1.2;
  color: #16362f;
  font-weight: 700;
}

.bind-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6f837c;
}

.bind-panel {
  margin-top: 14rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  border: 1rpx solid #e5ece8;
  background: #ffffff;
}

.bind-panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.bind-panel-title {
  font-size: 28rpx;
  color: #16362f;
  font-weight: 700;
}

.bind-error {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #d74b4b;
}

.bind-actions {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.bind-primary-btn,
.bind-secondary-btn {
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 12rpx;
}
