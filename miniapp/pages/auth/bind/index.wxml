<view class="bind-page">
  <view class="bind-header">
    <view class="bind-title">账号绑定</view>
    <view class="bind-subtitle">首次绑定后，后续可通过微信身份直接登录</view>
  </view>

  <van-notice-bar left-icon="volume-o" text="请绑定现有 CRM 账号，权限与后台保持一致。" />

  <view class="bind-panel">
    <view class="bind-panel-head">
      <view class="bind-panel-title">绑定信息</view>
      <van-tag type="primary" plain>首次必填</van-tag>
    </view>

    <van-cell-group inset="{{false}}" border="{{false}}">
      <van-field
        label="账号"
        value="{{username}}"
        placeholder="请输入 CRM 账号"
        data-field="username"
        bind:change="handleInput"
      />
      <van-field
        label="密码"
        password
        value="{{password}}"
        placeholder="请输入 CRM 密码"
        data-field="password"
        bind:change="handleInput"
      />
    </van-cell-group>

    <view wx:if="{{errorText}}" class="bind-error">{{errorText}}</view>

    <view class="bind-actions">
      <van-button type="primary" block custom-class="bind-primary-btn" loading="{{submitting}}" bindtap="handleBind">绑定并进入工作台</van-button>
      <van-button type="default" block custom-class="bind-secondary-btn" bindtap="handleBackLogin">返回登录校验页</van-button>
    </view>
  </view>
</view>
