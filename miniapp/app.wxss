@import "./miniprogram_npm/@vant/weapp/common/index.wxss";

page {
  --bg-page: #f4f7f6;
  --bg-top: #e7efeb;
  --surface: #ffffff;
  --surface-soft: #f8fbf9;
  --surface-alt: #eef4f1;
  --border: #d7e1dc;
  --text-1: #16362f;
  --text-2: #5f736c;
  --text-3: #8b9d96;
  --brand: #1f6b57;
  --brand-dark: #174c40;
  --brand-soft: #e6f0eb;
  --shadow: 0 18rpx 44rpx rgba(24, 58, 48, 0.06);
  min-height: 100%;
  background: linear-gradient(180deg, var(--bg-top) 0, #eef4f1 280rpx, var(--bg-page) 280rpx, var(--bg-page) 100%);
  color: var(--text-1);
  font-size: 28rpx;
}
page, view, text, button, input, textarea, picker, scroll-view { box-sizing: border-box; }
.page-shell { min-height: 100vh; padding: 28rpx 28rpx 40rpx; }
.hero-block { padding: 14rpx 8rpx 30rpx; }
.hero-kicker { display: inline-flex; align-items: center; min-height: 46rpx; padding: 0 18rpx; border-radius: 999rpx; background: rgba(255,255,255,.72); color: var(--brand-dark); font-size: 22rpx; font-weight: 700; letter-spacing: 2rpx; }
.hero-title { margin-top: 22rpx; font-size: 56rpx; line-height: 1.14; font-weight: 700; color: var(--text-1); }
.hero-subtitle { margin-top: 16rpx; font-size: 28rpx; line-height: 1.72; color: var(--text-2); }
.surface-card { background: var(--surface); border: 1rpx solid rgba(215,225,220,.95); border-radius: 30rpx; box-shadow: var(--shadow); }
.panel { padding: 30rpx; }
.panel-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 24rpx; }
.panel-title { font-size: 34rpx; line-height: 1.35; font-weight: 700; color: var(--text-1); }
.panel-copy { margin-top: 10rpx; font-size: 25rpx; line-height: 1.7; color: var(--text-2); }
.mini-link { color: var(--brand); font-size: 24rpx; font-weight: 700; }
.panel-gap { margin-top: 20rpx; }
.stats-grid { display: grid; grid-template-columns: repeat(3,minmax(0,1fr)); gap: 16rpx; }
.stat-card { padding: 20rpx; border-radius: 24rpx; background: var(--surface-soft); border: 1rpx solid rgba(215,225,220,.85); }
.stat-value { font-size: 38rpx; font-weight: 700; color: var(--text-1); }
.stat-label { margin-top: 10rpx; font-size: 22rpx; color: var(--text-3); }
.action-grid { display: grid; grid-template-columns: repeat(2,minmax(0,1fr)); gap: 18rpx; }
.action-card { position: relative; padding: 24rpx; border-radius: 26rpx; background: var(--surface-soft); border: 1rpx solid rgba(215,225,220,.85); }
.action-card-strong { background: linear-gradient(180deg,#214d42,#1c6051); border-color: transparent; }
.action-card-title { font-size: 30rpx; line-height: 1.35; font-weight: 700; color: var(--text-1); }
.action-card-strong .action-card-title, .action-card-strong .action-card-copy, .action-card-strong .action-card-meta { color: #fff; }
.action-card-copy { margin-top: 10rpx; font-size: 24rpx; line-height: 1.62; color: var(--text-2); }
.action-card-meta { margin-top: 18rpx; font-size: 22rpx; color: var(--brand); font-weight: 700; }
.row-list { display: flex; flex-direction: column; gap: 18rpx; }
.list-card { padding: 24rpx; border-radius: 24rpx; background: var(--surface-soft); border: 1rpx solid rgba(215,225,220,.8); }
.list-row { display: flex; align-items: center; justify-content: space-between; gap: 18rpx; }
.list-main { flex: 1; }
.list-title { font-size: 30rpx; line-height: 1.35; font-weight: 700; color: var(--text-1); }
.list-desc { margin-top: 8rpx; font-size: 24rpx; line-height: 1.62; color: var(--text-2); }
.list-aside { color: var(--brand); font-size: 24rpx; font-weight: 700; }
.tag-row { display: flex; flex-wrap: wrap; gap: 12rpx; }
.tag-chip { display: inline-flex; align-items: center; min-height: 44rpx; padding: 0 18rpx; border-radius: 999rpx; background: var(--brand-soft); color: var(--brand-dark); font-size: 22rpx; font-weight: 700; }
.tag-chip-muted { background: var(--surface-alt); color: var(--text-2); }
.field-block { margin-top: 26rpx; }
.field-label { display: block; margin-bottom: 14rpx; font-size: 28rpx; font-weight: 700; color: var(--text-1); }
.field-hint { margin-top: 10rpx; font-size: 22rpx; color: var(--text-3); }
.input, .textarea, .picker-field { width: 100%; min-height: 92rpx; border: 1rpx solid var(--border); border-radius: 22rpx; padding: 24rpx; background: var(--surface-soft); color: var(--text-1); }
.textarea { min-height: 208rpx; }
.input-placeholder, .textarea-placeholder, .picker-placeholder { color: var(--text-3); }
.primary-btn, .secondary-btn, .ghost-btn { width: 100%; border-radius: 22rpx; font-size: 30rpx; font-weight: 700; line-height: 92rpx; padding: 0; }
.primary-btn { background: linear-gradient(180deg,#24594b,#1f6b57); color: #fff; box-shadow: 0 16rpx 28rpx rgba(31,107,87,.18); }
.secondary-btn { background: var(--brand-soft); color: var(--brand-dark); }
.ghost-btn { background: #fff; color: var(--brand-dark); border: 1rpx solid var(--border); }
.primary-btn::after, .secondary-btn::after, .ghost-btn::after, .tab-inline-btn::after { border: none; }
.inline-actions { display: flex; gap: 18rpx; }
.inline-actions .primary-btn, .inline-actions .secondary-btn, .inline-actions .ghost-btn { flex: 1; }
.tab-inline-btn { min-width: 132rpx; height: 72rpx; line-height: 72rpx; padding: 0 24rpx; border-radius: 18rpx; background: #fff; border: 1rpx solid var(--border); color: var(--brand-dark); font-size: 26rpx; font-weight: 700; }
.empty-panel { padding: 88rpx 32rpx; text-align: center; }
.empty-title { font-size: 30rpx; font-weight: 700; color: var(--text-1); }
.empty-copy { margin-top: 14rpx; font-size: 25rpx; line-height: 1.72; color: var(--text-2); }
.placeholder-badge { display: inline-flex; align-items: center; min-height: 46rpx; padding: 0 18rpx; border-radius: 999rpx; background: var(--surface-alt); color: var(--brand-dark); font-size: 22rpx; font-weight: 700; }
.section-stack { display: flex; flex-direction: column; gap: 20rpx; }

.van-button--primary {
  background: linear-gradient(180deg, #24594b, #1f6b57);
  border-color: #1f6b57;
}

.van-button--default {
  color: var(--brand-dark);
}

.van-notice-bar {
  border-radius: 20rpx;
}

.van-search {
  padding: 0;
  background: transparent;
}

.van-search__content {
  background: var(--surface-soft);
  border-radius: 22rpx;
}

.van-cell,
.van-cell-group {
  background: transparent;
}

.van-cell {
  padding-left: 0;
  padding-right: 0;
}

.van-field__control,
.van-field__control--textarea {
  color: var(--text-1);
}
